.stats-section {
  margin: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 25rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.stats-item {
  background: linear-gradient(135deg, #ff6b35, #ff8c42);
  border-radius: 12rpx;
  padding: 30rpx 20rpx;
  text-align: center;
}

.stats-value {
  font-size: 40rpx;
  font-weight: 500;
  color: #fff;
  margin-bottom: 10rpx;
}

.stats-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.top-list {
  display: flex;
  flex-direction: column;
}

.empty-data {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 40rpx 0;
}

.top-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.top-item:last-child {
  border-bottom: none;
}

.top-rank {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background-color: var(--primary-color);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 500;
  margin-right: 20rpx;
}

.top-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.top-count {
  font-size: 26rpx;
  color: #999;
}

.status-list {
  display: flex;
  flex-direction: column;
}

.status-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.status-item:last-child {
  border-bottom: none;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 15rpx;
}

.status-dot.paid {
  background-color: var(--primary-color);
}

.status-dot.cooking {
  background-color: var(--primary-color);
}

.status-dot.delivering {
  background-color: var(--success-color);
}

.status-dot.completed {
  background-color: #999;
}

.status-dot.cancelled {
  background-color: var(--error-color);
}

.status-name {
  flex: 1;
  font-size: 26rpx;
  color: #666;
}

.status-count {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
