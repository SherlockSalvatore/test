<view class="page">
  <!-- 添加菜品按钮 -->
  <view class="header">
    <button class="add-btn" bindtap="showAddModal">➕ 添加菜品</button>
  </view>

  <!-- 菜品列表 -->
  <view class="menu-list">
    <view
      wx:for="{{menuList}}"
      wx:key="_id"
      class="menu-item card"
    >
      <image class="menu-image" src="{{item.image || '/images/placeholder.png'}}" mode="aspectFill"></image>
      <view class="menu-info">
        <view class="menu-header">
          <view class="menu-name">{{item.name}}</view>
          <view class="menu-tag {{item.available ? 'available' : 'unavailable'}}">
            {{item.available ? '在售' : '下架'}}
          </view>
        </view>
        <view class="menu-category">{{item.category}}</view>
        <view class="menu-price">¥{{item.price}}</view>
        <view class="menu-desc">{{item.description}}</view>
        <view class="menu-actions">
          <button class="action-btn edit-btn" bindtap="editItem" data-id="{{item._id}}">编辑</button>
          <button class="action-btn delete-btn" bindtap="deleteItem" data-id="{{item._id}}">删除</button>
          <button
            class="action-btn {{item.available ? 'disable-btn' : 'enable-btn'}}"
            bindtap="toggleStatus"
            data-id="{{item._id}}"
            data-status="{{item.available}}"
          >
            {{item.available ? '下架' : '上架'}}
          </button>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 添加/编辑弹窗 -->
<view wx:if="{{showModal}}" class="modal-mask" bindtap="hideModal">
  <view class="modal-content" catchtap="">
    <view class="modal-title">{{editingId ? '编辑菜品' : '添加菜品'}}</view>

    <view class="form-item">
      <text class="form-label">菜品名称</text>
      <input class="form-input" value="{{formData.name}}" bindinput="onNameInput" placeholder="请输入菜品名称" />
    </view>

    <view class="form-item">
      <text class="form-label">分类</text>
      <picker range="{{categories}}" bindchange="onCategoryChange">
        <view class="picker">{{formData.category || '请选择分类'}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">价格</text>
      <input class="form-input" type="digit" value="{{formData.price}}" bindinput="onPriceInput" placeholder="请输入价格" />
    </view>

    <view class="form-item">
      <text class="form-label">描述</text>
      <textarea class="form-textarea" value="{{formData.description}}" bindinput="onDescInput" placeholder="请输入菜品描述" />
    </view>

    <view class="form-item">
      <text class="form-label">图片</text>
      <button class="upload-btn" bindtap="chooseImage">选择图片</button>
      <image wx:if="{{formData.image}}" class="preview-image" src="{{formData.image}}" mode="aspectFill"></image>
    </view>

    <view class="modal-actions">
      <button class="modal-btn cancel-btn" bindtap="hideModal">取消</button>
      <button class="modal-btn confirm-btn" bindtap="saveItem">保存</button>
    </view>
  </view>
</view>
