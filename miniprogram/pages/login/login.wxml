<view class="login-container">
  <!-- Cartoon Header Area -->
  <view class="header-area">
    <image class="cartoon-clouds" src="/images/clouds.png" mode="widthFix" wx:if="{{false}}"></image> <!-- Placeholder for cloud image -->
    <view class="logo-circle">
      <view class="logo-emoji">👶🍲</view>
    </view>
    <view class="title">宝贝辅食外卖</view>
    <view class="subtitle">健康美味，妈妈安心</view>
  </view>

  <!-- Login Area -->
  <view class="login-box">
    <!-- One-click Login -->
    <button class="login-btn {{isAgreed ? '' : 'disabled'}}" bindgetphonenumber="loginAsUser" bindtap="checkAgreement">
      <view class="btn-content">
        <text class="btn-icon">微信</text>
        <text class="btn-text">一键登录</text>
      </view>
    </button>
    
    <!-- User Agreement -->
    <view class="agreement-section">
      <checkbox-group bindchange="onAgreementChange">
        <label class="checkbox-label">
          <checkbox class="mint-checkbox" value="agreed" checked="{{isAgreed}}" color="#4ade80" />
          <view class="agreement-text">
            我已阅读并同意 <text class="link" bindtap="goToAgreement">《用户服务协议》</text> 与 <text class="link" bindtap="goToPrivacy">《隐私政策》</text>
          </view>
        </label>
      </checkbox-group>
    </view>
  </view>

  <!-- Decorative Footer -->
  <view class="footer-decoration">
    <view class="wave"></view>
  </view>
</view>
