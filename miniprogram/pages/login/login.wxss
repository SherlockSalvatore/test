page {
  background-color: #f0fdf4; /* Mint green light background */
  font-family: 'Comic Sans MS', 'STHupo', 'PingFang SC', sans-serif;
}

.login-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* Header Area styling */
.header-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  position: relative;
  z-index: 2;
  width: 100%;
}

.cartoon-clouds {
  width: 100%;
  height: 500rpx;
  margin-bottom: 20rpx;
  border-radius: 0 0 40rpx 40rpx;
  box-shadow: 0 10rpx 20rpx rgba(0,0,0,0.1);
}

.title {
  color: #166534;
  font-size: 56rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
  letter-spacing: 6rpx;
  text-shadow: 3rpx 3rpx 0px #fff, -1rpx -1rpx 0 #fff, 1rpx -1rpx 0 #fff, -1rpx 1rpx 0 #fff, 1rpx 1rpx 0 #fff;
}

.subtitle {
  color: #22c55e;
  font-size: 28rpx;
  background-color: rgba(255, 255, 255, 0.6);
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
}

/* Login Box */
.login-box {
  padding: 60rpx 40rpx;
  background: white;
  border-radius: 60rpx 60rpx 0 0;
  box-shadow: 0 -10rpx 40rpx rgba(0, 0, 0, 0.05);
  z-index: 2;
  position: relative;
  min-height: 400rpx;
}

.login-btn {
  width: 90% !important;
  height: 100rpx;
  background: linear-gradient(135deg, #4ade80, #22c55e); /* Mint to Green */
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 20rpx rgba(34, 197, 94, 0.3);
  margin-bottom: 40rpx;
  margin-top: 20rpx;
}

.login-btn.disabled {
  background: #d1d5db; /* Gray out if disabled */
  box-shadow: none;
}

.login-btn::after {
  border: none;
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 36rpx;
  font-weight: bold;
}

.btn-icon {
  margin-right: 16rpx;
}

.btn-active {
  transform: scale(0.98);
}

/* Agreement Section */
.agreement-section {
  display: flex;
  justify-content: center;
  align-items: flex-start;
  padding: 0 20rpx;
}

.checkbox-label {
  display: flex;
  align-items: flex-start;
}

.mint-checkbox {
  transform: scale(0.7);
  margin-top: -6rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
  flex: 1;
}

.link {
  color: #22c55e;
  font-weight: 500;
}

/* Base cartoon decorators */
.footer-decoration {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 150rpx;
  background: #f0fdf4;
  z-index: 1;
}

/* --- Popup Styles --- */
.popup-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 999;
  display: flex;
  justify-content: center;
  align-items: flex-end; /* Bottom sheet style */
}

.popup-content {
  background: white;
  width: 100%;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx;
  box-sizing: border-box;
  animation: slideUp 0.3s ease-out forwards;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.popup-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.popup-close {
  font-size: 48rpx;
  color: #999;
  padding: 0 20rpx;
}

.popup-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 40rpx;
}

.popup-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
  border: 4rpx solid #4ade80;
}

.popup-desc {
  font-size: 28rpx;
  color: #666;
  text-align: center;
}

/* Adjusted agreement section for popup */
.agreement-section {
  display: flex;
  align-items: flex-start;
  margin-bottom: 40rpx;
  padding: 0;
}

.checkbox-label {
  margin-right: 10rpx;
}

.agreement-text {
  flex: 1;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-top: -2rpx; /* visually align with checkbox */
}

.popup-footer {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx; /* avoid safe area issues */
}

.popup-btn {
  flex: 1;
  height: 90rpx;
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
}

.popup-btn::after {
  border: none;
}

.popup-btn-cancel {
  background: #f3f4f6;
  color: #4b5563;
}

.popup-btn-confirm {
  background: #22c55e;
  color: white;
  box-shadow: 0 4rpx 10rpx rgba(34, 197, 94, 0.3);
}
