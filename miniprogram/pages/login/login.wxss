page {
  background-color: #f0fdf4; /* Mint green light background */
  font-family: 'Comic Sans MS', 'STHupo', 'PingFang SC', sans-serif;
}

.login-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* Header Area styling */
.header-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 120rpx;
  position: relative;
  z-index: 2;
}

.logo-circle {
  width: 200rpx;
  height: 200rpx;
  background-color: #bbf7d0; /* Mint green circle */
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 30rpx rgba(74, 222, 128, 0.3);
  margin-bottom: 30rpx;
  border: 8rpx solid #fff;
}

.logo-emoji {
  font-size: 100rpx;
}

.title {
  color: #166534;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  letter-spacing: 4rpx;
  text-shadow: 2rpx 2rpx 0px rgba(255,255,255,0.8);
}

.subtitle {
  color: #22c55e;
  font-size: 28rpx;
  background-color: rgba(255, 255, 255, 0.6);
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
}

/* Login Box */
.login-box {
  padding: 60rpx 40rpx;
  background: white;
  border-radius: 60rpx 60rpx 0 0;
  box-shadow: 0 -10rpx 40rpx rgba(0, 0, 0, 0.05);
  z-index: 2;
  position: relative;
  min-height: 400rpx;
}

.login-btn {
  width: 90% !important;
  height: 100rpx;
  background: linear-gradient(135deg, #4ade80, #22c55e); /* Mint to Green */
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 20rpx rgba(34, 197, 94, 0.3);
  margin-bottom: 40rpx;
  margin-top: 20rpx;
}

.login-btn.disabled {
  background: #d1d5db; /* Gray out if disabled */
  box-shadow: none;
}

.login-btn::after {
  border: none;
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 36rpx;
  font-weight: bold;
}

.btn-icon {
  margin-right: 16rpx;
}

.btn-active {
  transform: scale(0.98);
}

/* Agreement Section */
.agreement-section {
  display: flex;
  justify-content: center;
  align-items: flex-start;
  padding: 0 20rpx;
}

.checkbox-label {
  display: flex;
  align-items: flex-start;
}

.mint-checkbox {
  transform: scale(0.7);
  margin-top: -6rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
  flex: 1;
}

.link {
  color: #22c55e;
  font-weight: 500;
}

/* Base cartoon decorators */
.footer-decoration {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 150rpx;
  background: #f0fdf4;
  z-index: 1;
}
