.tabs {
  display: flex;
  background: #fff;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
  border-radius: 0 0 20rpx 20rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.02);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #4ade80; /* Mint Green */
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #4ade80; /* Mint Green */
  border-radius: 4rpx;
}

/* Base styles imported previously */
.empty-orders {
  min-height: 70vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.empty-icon {
  font-size: 150rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
}

.order-list {
  padding: 10rpx 20rpx 40rpx;
}

.order-item {
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0fdf4;
}

.order-id {
  font-size: 24rpx;
  color: #999;
}

.order-status {
  font-size: 26rpx;
  font-weight: bold;
}

.order-status.pending {
  color: #f59e0b; /* Amber */
}

.order-status.paid {
  color: #4ade80; /* Mint */
}

.order-status.cooking {
  color: #3b82f6; /* Blue */
}

.order-status.delivering {
  color: #10b981; /* Emerald */
}

.order-status.completed {
  color: #9ca3af; /* Gray */
}

.order-status.cancelled {
  color: #ef4444; /* Red */
}

.order-items {
  padding: 24rpx 0;
}

.item-summary {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  color: #374151;
  margin-bottom: 12rpx;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx dashed #eee;
}

.order-time {
  font-size: 24rpx;
  color: #999;
}

.order-amount {
  font-size: 34rpx;
  color: #111827;
  font-weight: bold;
}
