.empty-orders {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.empty-icon {
  font-size: 150rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
}

.order-list {
  padding: 20rpx;
}

.order-item {
  margin-bottom: 20rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.order-id {
  font-size: 24rpx;
  color: #999;
}

.order-status {
  font-size: 26rpx;
  font-weight: 500;
}

.order-status.pending {
  color: var(--warning-color);
}

.order-status.paid {
  color: var(--primary-color);
}

.order-status.cooking {
  color: var(--primary-color);
}

.order-status.delivering {
  color: var(--success-color);
}

.order-status.completed {
  color: var(--text-secondary);
}

.order-status.cancelled {
  color: var(--error-color);
}

.order-items {
  padding: 20rpx 0;
}

.item-summary {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.order-time {
  font-size: 24rpx;
  color: #999;
}

.order-amount {
  font-size: 32rpx;
  color: var(--primary-color);
  font-weight: 500;
}
