<view class="page">
  <!-- 顶部状态分类 Tab -->
  <view class="tabs">
    <view class="tab-item {{currentStatus === 'all' ? 'active' : ''}}" bindtap="switchTab" data-status="all">全部</view>
    <view class="tab-item {{currentStatus === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-status="pending">待支付</view>
    <view class="tab-item {{currentStatus === 'delivering' ? 'active' : ''}}" bindtap="switchTab" data-status="delivering">配送中</view>
    <view class="tab-item {{currentStatus === 'completed' ? 'active' : ''}}" bindtap="switchTab" data-status="completed">已完成</view>
  </view>
  <view wx:if="{{orderList.length === 0}}" class="empty-orders">
    <view class="empty-icon">📋</view>
    <view class="empty-text">暂无订单</view>
  </view>

  <view wx:else class="order-list">
    <view
      wx:for="{{orderList}}"
      wx:key="_id"
      class="order-item card"
      bindtap="goToDetail"
      data-id="{{item._id}}"
    >
      <view class="order-header">
        <view class="order-id">订单号：{{item.outTradeNo ? item.outTradeNo : item._id}}</view>
        <view class="order-status {{getStatusClass(item.status)}}">{{getStatusText(item.status)}}</view>
      </view>
      <view class="order-items">
        <view wx:for="{{item.items}}" wx:key="menuId" wx:for-item="subItem" class="item-summary">
          <text>{{subItem.name}}</text>
          <text>x{{subItem.quantity}}</text>
        </view>
      </view>
      <view class="order-footer">
        <view class="order-time">{{formatTime(item.createTime)}}</view>
        <view class="order-amount">¥{{item.totalAmount}}</view>
      </view>
    </view>
  </view>
</view>
