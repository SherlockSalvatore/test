page {
  background-color: #f0fdf4;
  font-family: 'Comic Sans MS', 'STHupo', 'PingFang SC', sans-serif;
  padding-bottom: 160rpx; /* Space for checkout bar */
}

/* Empty Cart */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 20rpx;
  opacity: 0.8;
}

.empty-text {
  font-size: 32rpx;
  color: #6b7280;
  margin-bottom: 50rpx;
  font-weight: bold;
}

.go-order-btn {
  background: linear-gradient(135deg, #4ade80, #22c55e);
  color: white;
  width: 320rpx !important;
  height: 90rpx;
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 20rpx rgba(34, 197, 94, 0.3);
}

.go-order-btn::after {
  border: none;
}

/* Cart List */
.cart-list {
  padding: 30rpx 20rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  padding: 30rpx 20rpx;
}

.check-box {
  padding: 0 10rpx;
}

.item-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  background-color: #f3f4f6;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 120rpx;
}

.item-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.item-price {
  font-size: 36rpx;
  color: #f59e0b;
  font-weight: bold;
}

/* Plus Minus Buttons */
.item-control {
  display: flex;
  align-items: center;
  background: #f3f4f6;
  border-radius: 30rpx;
  padding: 4rpx;
}

.btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #4ade80;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 6rpx rgba(74, 222, 128, 0.3);
}

.btn.minus {
  background-color: #ffffff;
  color: #4ade80;
  border: 2rpx solid #4ade80;
  box-shadow: none;
}

.quantity {
  width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #1f2937;
}

/* Delivery Section */
.delivery-section {
  background: white;
  border-radius: 24rpx;
  margin: 0 20rpx 40rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(34, 197, 94, 0.08);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 34rpx;
  color: #166534;
}

.input-group {
  margin-bottom: 24rpx;
}

.input-field {
  width: 100%;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 90rpx; /* Set explicit height instead of large padding to avoid squishing */
  font-size: 30rpx; /* Slightly larger for clarity */
  font-family: inherit; /* Ensure it inherits the modern page fonts */
  color: #374151;
  box-sizing: border-box;
  transition: all 0.3s;
}

.input-field:focus {
  border-color: #4ade80;
  background: #f0fdf4;
}

.textarea-field {
  width: 100%;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 24rpx;
  height: 160rpx;
  font-size: 30rpx;
  font-family: inherit;
  color: #374151;
  box-sizing: border-box;
}

/* Checkout Bar */
.checkout-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 140rpx;
  background-color: white;
  border-radius: 40rpx 40rpx 0 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx 20rpx; /* Bottom padding for safe area */
  box-shadow: 0 -10rpx 30rpx rgba(0,0,0,0.05);
  z-index: 100;
}

.total-info {
  display: flex;
  flex-direction: column;
}

.fee-label {
  font-size: 22rpx;
  color: #9ca3af;
  margin-bottom: 4rpx;
}

.price-row {
  display: flex;
  align-items:baseline;
}

.total-label {
  font-size: 28rpx;
  color: #374151;
  font-weight: bold;
  margin-right: 10rpx;
}

.total-price {
  font-size: 44rpx;
  color: #f59e0b;
  font-weight: bold;
}

/* 底部结算栏 */
.cart-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: white;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 40rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
  z-index: 100;
}

.footer-left {
  display: flex;
  align-items: center;
}

.all-text {
  font-size: 28rpx;
  color: #64748b;
  margin-left: 12rpx;
}

.footer-right {
  display: flex;
  align-items: center;
}

.total-info {
  margin-right: 24rpx;
  text-align: right;
}

.total-label {
  font-size: 24rpx;
  color: #64748b;
}

.total-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ef4444;
}

.checkout-btn {
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: white;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
  margin: 0 !important;
}

.checkout-btn::after {
  border: none;
}
