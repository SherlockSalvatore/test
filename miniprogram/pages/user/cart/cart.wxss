page {
  background-color: #f6f7f9;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  padding-bottom: 120rpx;
}

/* 1. 列表区域 */
.cart-list {
  padding: 24rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.02);
}

.check-box {
  padding-right: 20rpx;
  display: flex;
  align-items: center;
}

.item-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background-color: #f1f5f9;
}

.item-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 180rpx; /* 与图片等高 */
  padding: 4rpx 0;
}

.item-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1e293b;
  line-height: 1.4;
  /* 限制两行 */
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.item-price {
  font-size: 36rpx;
  color: #fa4d32; /* 盒马红色 */
  font-weight: bold;
}

/* 数量加减器 */
.quantity-control {
  display: flex;
  align-items: center;
  border: 1rpx solid #e2e8f0;
  border-radius: 30rpx;
  padding: 2rpx;
}

.btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #334155;
  font-weight: bold;
}

.btn.minus {
  color: #94a3b8;
}

.btn.plus {
  background-color: #008cff; /* 盒马蓝 */
  color: white;
  border-radius: 50%;
  width: 40rpx;
  height: 40rpx;
  margin: 2rpx;
}

.num {
  width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  color: #1e293b;
}

/* 2. 空状态 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #94a3b8;
  margin-bottom: 60rpx;
}

.go-btn {
  background: #008cff;
  color: white;
  border-radius: 40rpx;
  padding: 0 60rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}

/* 3. 底部结算栏 */
.cart-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: white;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
  z-index: 100;
}

.footer-left {
  display: flex;
  align-items: center;
}

.all-text {
  font-size: 26rpx;
  color: #64748b;
  margin-left: 10rpx;
}

.footer-right {
  display: flex;
  align-items: center;
}

.total-info {
  text-align: right;
  margin-right: 20rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
}

.total-label {
  font-size: 24rpx;
  color: #1e293b;
}

.total-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #fa4d32;
}

.fee-summary {
  font-size: 20rpx;
  color: #94a3b8;
  margin-top: 2rpx;
}

.checkout-btn {
  background: #008cff;
  color: white;
  height: 80rpx;
  border-radius: 40rpx;
  padding: 0 40rpx;
  font-size: 30rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 !important;
}
