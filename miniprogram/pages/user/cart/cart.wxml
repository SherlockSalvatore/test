<view class="page">
  <!-- 1. 购物车列表 (List) -->
  <view wx:if="{{cartList.length > 0}}" class="cart-container">
    <view class="cart-list">
      <view class="cart-item card" wx:for="{{cartList}}" wx:key="_id">
        <view class="check-box" bindtap="toggleCheck" data-id="{{item._id}}" data-checked="{{item.checked}}">
          <icon type="{{item.checked ? 'success' : 'circle'}}" size="22" color="{{item.checked ? '#22c55e' : '#cbd5e1'}}"></icon>
        </view>
        <image class="item-img" src="{{item.image}}" mode="aspectFill"></image>
        <view class="item-info">
          <view class="item-name">{{item.name}}</view>
          <view class="item-bottom">
            <view class="item-price">¥{{item.price}}</view>
            <view class="quantity-control">
              <view class="btn minus" bindtap="decrease" data-id="{{item._id}}" data-quantity="{{item.quantity}}">-</view>
              <view class="num">{{item.quantity}}</view>
              <view class="btn plus" bindtap="increase" data-id="{{item._id}}">+</view>
            </view>
          </view>
        </view>
      </view>
    </view>
    <view style="height: 140rpx;"></view>
  </view>

  <!-- 2. 空状态 (Empty) -->
  <view wx:else class="empty-cart">
    <view class="empty-icon">🛒</view>
    <view class="empty-text">您的购物车还空空如也~</view>
    <button class="go-btn" bindtap="goToHome">去挑选美食</button>
  </view>

  <!-- 3. 底部结算栏 (Footer) -->
  <view wx:if="{{cartList.length > 0}}" class="cart-footer">
    <view class="footer-left" bindtap="toggleCheckAll">
      <icon type="{{checkAll ? 'success' : 'circle'}}" size="22" color="{{checkAll ? '#22c55e' : '#cbd5e1'}}"></icon>
      <text class="all-text">全选</text>
    </view>
    <view class="footer-right">
      <view class="total-info">
        <text class="total-label">合计：</text>
        <text class="total-price">¥{{totalPrice}}</text>
      </view>
      <button class="checkout-btn" bindtap="goToCheckout">
        结算({{selectedCount}})
      </button>
    </view>
  </view>
</view>
