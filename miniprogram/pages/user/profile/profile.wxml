<view class="page">
  <!-- 头像 & 昵称区域 (Avatar & Nickname Section) -->
  <view class="user-header-card">
    <button class="avatar-wrapper" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/header.png'}}" mode="aspectFill"></image>
      <view class="edit-badge">✏️</view>
    </button>
    
    <view class="user-info">
      <input 
        type="nickname" 
        class="nickname-input" 
        placeholder="点此输入昵称" 
        placeholder-style="color: #a7f3d0;"
        value="{{userInfo.nickName}}" 
        bindblur="onNicknameInput" 
        bindchange="onNicknameChange"
      />
      <view class="welcome-text">欢迎来到璐璐私房菜！</view>
    </view>
  </view>

  <!-- 我的订单 (My Orders) -->
  <view class="menu-section card">
    <view class="section-title">
      <text class="title-icon">🛍️</text>
      <text>我的订单</text>
    </view>
    <view class="order-menus">
      <view class="order-menu-item" bindtap="goToOrders" data-status="all">
        <view class="menu-icon">📋</view>
        <view class="menu-text">全部订单</view>
      </view>
      <view class="order-menu-item" bindtap="goToOrders" data-status="pending">
        <view class="menu-icon">🕐</view>
        <view class="menu-text">待支付</view>
      </view>
      <view class="order-menu-item" bindtap="goToOrders" data-status="delivering">
        <view class="menu-icon">🛵</view>
        <view class="menu-text">配送中</view>
      </view>
      <view class="order-menu-item" bindtap="goToOrders" data-status="completed">
        <view class="menu-icon">✅</view>
        <view class="menu-text">已完成</view>
      </view>
    </view>
  </view>

  <!-- 其他功能 (Other Features) -->
  <view class="other-section card">
    <view class="menu-list-item" bindtap="showAbout">
      <view class="item-left">
        <text class="item-icon">👨‍🍳</text>
        <text class="item-text">关于璐璐私房菜</text>
      </view>
      <text class="item-arrow">👉</text>
    </view>
  </view>

  <!-- 退出登录 (Logout) -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="logout">退出登录</button>
  </view>
</view>
