<wxs module="helper">
    var getCount = function(item, cart) {
      if (!cart || !cart.length) return 0;
      for (var i = 0; i < cart.length; i++) {
        if (cart[i].menuId === item._id) return cart[i].quantity;
      }
      return 0;
    }
    var getPurchaseCount = function(itemId, orderedItemCounts) {
      if (!orderedItemCounts) return 0;
      return orderedItemCounts[itemId] || 0;
    }
    module.exports = {
      getCount: getCount,
      getPurchaseCount: getPurchaseCount
    }
  </wxs>

<view class="page">
  <!-- Top Banner Image -->
  <view class="home-header">
    <image class="header-image" src="/images/header.png" mode="aspectFill"></image>
  </view>

  <!-- Main Content Area -->
  <view class="content-container">
    
    <!-- Category Sidebar (Left) -->
    <scroll-view scroll-y class="category-sidebar">
      <view
        wx:for="{{categories}}"
        wx:key="*this"
        class="category-item {{currentCategory === item ? 'active' : ''}}"
        bindtap="switchCategory"
        data-category="{{item}}"
      >
        {{item}}
      </view>
    </scroll-view>

    <!-- Menu List (Right) -->
    <scroll-view scroll-y class="menu-list">
      <view
        wx:for="{{menuList}}"
        wx:key="_id"
      >
        <view class="image-wrapper">
          <image class="menu-image" src="{{item.image || '/images/placeholder.png'}}" mode="aspectFill"></image>
          <view wx:if="{{helper.getPurchaseCount(item._id, orderedItemCounts) > 0}}" class="bought-tag">回购 {{orderedItemCounts[item._id]}} 次</view>
        </view>
        <view class="menu-info">
          <view class="menu-name">
            {{item.name}}
          </view>
          <view class="menu-desc">{{item.description}}</view>
          <view class="menu-bottom">
            <view class="menu-price">¥{{item.price}}</view>
            <view class="quantity-control">
              <block wx:if="{{helper.getCount(item, cart) > 0}}">
                <view class="btn minus" catchtap="decreaseQuantity" data-item="{{item}}">-</view>
                <view class="quantity">{{helper.getCount(item, cart)}}</view>
              </block>
              <view class="btn plus" catchtap="increaseQuantity" data-item="{{item}}">+</view>
            </view>
          </view>
        </view>
      </view>
      <!-- Bottom spacing for cart -->
      <view style="height: 180rpx;"></view>
    </scroll-view>

  </view>

  <!-- Floating Cart -->
  <view wx:if="{{cartTotal > 0}}" class="cart-bar" bindtap="goToCart">
    <view class="cart-info">
      <view class="cart-icon-wrapper">
        <text class="cart-icon">🛒</text>
        <view class="cart-count">{{cartTotal}}</view>
      </view>
      <view class="cart-total">¥{{cartAmount}}</view>
    </view>
    <view class="cart-btn">去结算</view>
  </view>
</view>
