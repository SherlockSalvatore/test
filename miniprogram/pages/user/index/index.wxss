page {
  background-color: #f0fdf4; /* Mint green background */
  font-family: 'Comic Sans MS', 'STHupo', 'PingFang SC', sans-serif;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* Header image area */
.home-header {
  width: 100%;
  height: 300rpx;
  background-color: #bbf7d0;
  border-radius: 0 0 40rpx 40rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.05);
  position: relative;
  z-index: 10;
}

.header-image {
  width: 100%;
  height: 100%;
}

/* Category Tabs - Side Menu Style */
.content-container {
  display: flex;
  flex: 1;
  overflow: hidden;
  margin-top: 10rpx;
}

.category-sidebar {
  width: 180rpx;
  background-color: #e0f2fe; /* Light blue tint for sidebar */
  height: 100%;
}

.category-item {
  padding: 30rpx 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #4b5563;
  position: relative;
  transition: all 0.3s;
}

.category-item.active {
  background-color: #f0fdf4;
  color: #166534;
  font-weight: bold;
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 20%;
  height: 60%;
  width: 8rpx;
  background-color: #22c55e;
  border-radius: 0 4rpx 4rpx 0;
}

/* Main Menu List */
.menu-list {
  flex: 1;
  height: 100%;
  padding: 20rpx;
  box-sizing: border-box;
}

.menu-item {
  display: flex;
  background: white;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 15rpx rgba(34, 197, 94, 0.08); /* Mint green shadow */
}

.menu-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background-color: #f3f4f6;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.menu-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.menu-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: auto;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.menu-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 10rpx;
}

.menu-price {
  font-size: 36rpx;
  color: #f59e0b;
  font-weight: bold;
}

.quantity-control {
  display: flex;
  align-items: center;
  background: #f3f4f6;
  border-radius: 30rpx;
  padding: 4rpx;
}

.btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #4ade80;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 6rpx rgba(74, 222, 128, 0.3);
}

.btn.minus {
  background-color: white;
  color: #4ade80;
  border: 2rpx solid #4ade80;
  box-shadow: none;
}

.btn.disabled {
  opacity: 0;
  pointer-events: none;
}

.quantity {
  width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  opacity: 1;
  transition: opacity 0.2s;
}

.quantity.hidden {
  opacity: 0;
}

/* 购物车浮层 */
.cart-bar {
  position: fixed;
  bottom: 40rpx;
  left: 40rpx;
  right: 40rpx;
  height: 100rpx;
  background-color: #1f2937;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 10rpx 25rpx rgba(0,0,0,0.2);
  z-index: 100;
}

.cart-info {
  display: flex;
  align-items: center;
  color: #fff;
}

.cart-icon-wrapper {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  background: #f59e0b;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: -30rpx;
  border: 6rpx solid #1f2937;
}

.cart-icon {
  font-size: 40rpx;
}

.cart-count {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background-color: #ef4444;
  color: white;
  border-radius: 50%;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
  border: 4rpx solid #1f2937;
}

.cart-total {
  font-size: 36rpx;
  font-weight: bold;
  margin-left: 20rpx;
}

.cart-btn {
  background-color: #22c55e;
  color: #fff;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 10rpx rgba(34, 197, 94, 0.4);
}
