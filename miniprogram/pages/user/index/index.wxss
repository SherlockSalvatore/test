.category-tabs {
  display: flex;
  background-color: #fff;
  padding: 20rpx;
  white-space: nowrap;
  position: sticky;
  top: 0;
  z-index: 10;
}

.category-item {
  padding: 12rpx 32rpx;
  margin-right: 20rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #666;
}

.category-item.active {
  background-color: var(--primary-color);
  color: #fff;
}

.menu-list {
  flex: 1;
  height: calc(100vh - 200rpx);
}

.menu-item {
  display: flex;
  margin: 20rpx;
  padding: 20rpx;
}

.menu-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background-color: #eee;
  margin-right: 20rpx;
}

.menu-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.menu-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 10rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: auto;
}

.menu-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.menu-price {
  font-size: 36rpx;
  color: var(--primary-color);
  font-weight: 500;
}

.quantity-control {
  display: flex;
  align-items: center;
}

.btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: var(--primary-color);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.btn.minus {
  background-color: #f5f5f5;
  color: #666;
}

.btn.disabled {
  opacity: 0.3;
}

.quantity {
  width: 60rpx;
  text-align: center;
  font-size: 28rpx;
}

/* 购物车浮层 */
.cart-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background-color: #333;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.cart-info {
  display: flex;
  align-items: center;
  color: #fff;
}

.cart-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.cart-count {
  background-color: var(--error-color);
  border-radius: 50%;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  margin-right: 20rpx;
}

.cart-total {
  font-size: 36rpx;
  font-weight: 500;
}

.cart-btn {
  background-color: var(--primary-color);
  color: #fff;
  padding: 20rpx 50rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}
