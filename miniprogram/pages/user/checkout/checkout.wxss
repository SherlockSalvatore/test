.page {
  padding: 24rpx;
  background-color: #f0fdf4;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* 地址卡片 */
.address-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  margin-bottom: 24rpx;
  background: white;
  border-radius: 20rpx;
}

.address-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
}

.address-info {
  flex: 1;
}

.addr-top {
  margin-bottom: 8rpx;
}

.name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1e293b;
  margin-right: 20rpx;
}

.phone {
  font-size: 28rpx;
  color: #64748b;
}

.addr-detail {
  font-size: 26rpx;
  color: #475569;
}

.address-empty {
  flex: 1;
  font-size: 30rpx;
  color: #94a3b8;
}

.arrow-icon {
  font-size: 24rpx;
  color: #94a3b8;
  margin-left: 20rpx;
}

/* 订单明细 */
.order-card {
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #166534;
  margin-bottom: 30rpx;
  border-left: 6rpx solid #22c55e;
  padding-left: 16rpx;
}

.item {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.item-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 500;
}

.item-spec {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

.item-price {
  font-size: 28rpx;
  font-weight: 500;
  color: #1e293b;
}

/* 费用汇总 */
.cost-card {
  padding: 30rpx;
}

.cost-item {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 20rpx;
}

.total-line {
  height: 1rpx;
  background: #f1f5f9;
  margin: 20rpx 0;
}

.final-price {
  text-align: right;
  font-size: 30rpx;
  color: #1e293b;
}

.price-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #ef4444;
}

/* 底部栏 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: white;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
}

.price-container {
  display: flex;
  align-items: baseline;
}

.price-container .label {
  font-size: 26rpx;
  color: #64748b;
}

.price-container .price {
  font-size: 40rpx;
  font-weight: bold;
  color: #ef4444;
}

.submit-btn {
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: white;
  width: 240rpx;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  box-shadow: 0 8rpx 20rpx rgba(34, 197, 94, 0.2);
}
