.loading {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #94a3b8;
}

.card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03);
}

.mt-20 { margin-top: 24rpx; }

/* 1. 状态区 */
.status-section {
  text-align: center;
  padding: 60rpx 40rpx;
  background: white;
}

.status-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.status-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #1e293b;
  margin-bottom: 12rpx;
}

/* 颜色状态码 */
.status-text.pending { color: #f59e0b; }
.status-text.paid, .status-text.cooking { color: #008cff; }
.status-text.delivering { color: #22c55e; }
.status-text.completed { color: #64748b; }
.status-text.cancelled { color: #94a3b8; }

.status-tip {
  font-size: 26rpx;
  color: #94a3b8;
}

/* 2. 信息板块标题 */
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1e293b;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.address-item, .info-item {
  display: flex;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  line-height: 1.6;
  color: #1e293b;
}

.label {
  color: #64748b;
  width: 160rpx;
  flex-shrink: 0;
}

/* 3. 订单列表 */
.item-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f8fafc;
}

.item-name {
  font-size: 28rpx;
  color: #1e293b;
}

.item-info {
  display: flex;
  align-items: center;
}

.item-qty {
  font-size: 24rpx;
  color: #94a3b8;
  margin-right: 24rpx;
}

.item-price {
  font-size: 28rpx;
  font-weight: 500;
  color: #1e293b;
}

.delivery-row {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #64748b;
}

.total-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 30rpx;
  margin-top: 10rpx;
  border-top: 2rpx dashed #f1f5f9;
}

.total-price {
  font-size: 40rpx;
  color: #ef4444;
  font-weight: bold;
}

/* 4. 操作按钮 - 重点重构视觉 */
.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 30rpx 40rpx 50rpx;
  display: flex;
  gap: 30rpx;
  box-shadow: 0 -10rpx 40rpx rgba(0,0,0,0.05);
}

.action-btn {
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}

/* 取消按钮：更深的中灰色 */
.cancel-btn {
  background-color: #475569; 
  color: #ffffff;
}

/* 支付按钮：鲜艳的主题蓝色 */
.pay-btn {
  background-color: #008cff;
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(0, 140, 255, 0.3);
}

/* 页面底部留出按钮高度空间 */
.page {
  padding-bottom: 200rpx;
  background-color: #f8fafc;
  min-height: 100vh;
}
