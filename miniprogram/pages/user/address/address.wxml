<view class="page">
  <!-- 1. 地址列表视图 (List View) -->
  <block wx:if="{{!showForm}}">
    <view class="header-bar">
      <view class="title">我的收货地址</view>
      <view class="add-txt-btn" bindtap="goToAdd">+ 新增地址</view>
    </view>

    <view wx:if="{{addressList.length === 0}}" class="empty-status">
      <view class="empty-icon">📍</view>
      <view class="empty-tip">还没有收货地址，点击右上角添加吧</view>
    </view>

    <view class="address-list">
      <view class="address-item card" wx:for="{{addressList}}" wx:key="_id" bindtap="selectAddress" data-id="{{item._id}}">
        <view class="addr-info">
          <view class="addr-top">
            <text class="addr-name">{{item.name}}</text>
            <text class="addr-phone">{{item.phone}}</text>
            <text wx:if="{{item.isDefault}}" class="default-tag">默认</text>
          </view>
          <view class="addr-detail">{{item.detail}}</view>
        </view>
        <view class="addr-edit-btn" catchtap="goToEdit" data-id="{{item._id}}">
          <text class="edit-icon">✏️</text>
        </view>
      </view>
    </view>
  </block>

  <!-- 2. 新增/编辑表单视图 (Form View) -->
  <block wx:else>
    <view class="form-title">{{editingId ? '编辑地址' : '新增收货地址'}}</view>
    <view class="address-card card">
      <view class="input-group">
        <text class="label">姓名</text>
        <input class="input" placeholder="请输入收货人姓名" value="{{name}}" bindinput="onNameInput" />
      </view>

      <view class="input-group">
        <text class="label">手机号</text>
        <input class="input" type="number" placeholder="请输入联系电话" value="{{phone}}" bindinput="onPhoneInput" />
      </view>

      <view class="input-group border-none">
        <text class="label">详细地址</text>
        <textarea class="textarea" placeholder="如：XX小区1栋1单元101" value="{{detail}}" bindinput="onDetailInput" />
      </view>
    </view>

    <view class="setting-list card">
      <view class="setting-item">
        <text>设为默认地址</text>
        <switch checked="{{isDefault}}" color="#22c55e" bindchange="onDefaultChange" />
      </view>
    </view>

    <view class="action-btns">
      <button class="save-btn" bindtap="saveAddress">保存地址</button>
      <button wx:if="{{editingId}}" class="delete-btn" bindtap="deleteAddress">删除此地址</button>
      <button class="cancel-btn" bindtap="cancelEdit">取消</button>
    </view>
  </block>
</view>
