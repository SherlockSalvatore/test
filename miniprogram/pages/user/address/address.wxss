.page {
  padding: 30rpx;
  background-color: #f8fafc;
  min-height: 100vh;
}

.address-card {
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1e293b;
  margin-bottom: 30rpx;
  padding-left: 10rpx;
  border-left: 8rpx solid #22c55e;
}

.input-group {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.border-none {
  border-bottom: none;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  font-size: 30rpx;
  color: #334155;
}

.textarea {
  width: 100%;
  height: 160rpx;
  font-size: 30rpx;
  color: #334155;
  padding-top: 10rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #94a3b8;
  text-align: center;
  margin-top: 20rpx;
}

.save-btn {
  margin-top: 60rpx;
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: #fff;
  border-radius: 40rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 20rpx rgba(34, 197, 94, 0.2);
}
