.page {
  padding: 30rpx;
  background-color: #f0fdf4; /* 浅绿背景 */
  min-height: 100vh;
}

/* 顶部栏 */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
  padding: 0 10rpx;
}

.header-bar .title {
  font-size: 34rpx;
  font-weight: bold;
  color: #166534;
}

.add-txt-btn {
  color: #22c55e;
  font-size: 30rpx;
  font-weight: bold;
}

/* 地址列表 */
.address-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.addr-info {
  flex: 1;
}

.addr-top {
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.addr-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1e293b;
  margin-right: 20rpx;
}

.addr-phone {
  font-size: 28rpx;
  color: #64748b;
}

.default-tag {
  background: #dcfce7;
  color: #166534;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 20rpx;
  font-weight: bold;
}

.addr-detail {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.5;
}

.addr-edit-btn {
  padding: 20rpx;
  margin-right: -10rpx;
}

.edit-icon {
  font-size: 36rpx;
}

/* 表单视图 */
.form-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #166534;
  margin-bottom: 40rpx;
  text-align: center;
}

.input-group {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.border-none { border-bottom: none; }

.label {
  display: block;
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 12rpx;
}

.input { height: 80rpx; font-size: 30rpx; color: #334155; }
.textarea { width: 100%; height: 160rpx; font-size: 30rpx; color: #334155; padding-top: 10rpx; }

/* 默认设置 */
.setting-list { padding: 30rpx; margin-top: 30rpx; }
.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  color: #334155;
}

/* 按钮区域 */
.action-btns { margin-top: 60rpx; }

.save-btn {
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: #fff;
  border-radius: 50rpx;
  font-weight: bold;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 20rpx rgba(34, 197, 94, 0.2);
}

.delete-btn {
  background: #fff;
  color: #ef4444;
  border: 2rpx solid #fee2e2;
  border-radius: 50rpx;
  margin-bottom: 30rpx;
}

.cancel-btn {
  background: transparent;
  color: #94a3b8;
  font-size: 28rpx;
}

.cancel-btn::after { border: none; }

/* 空状态 */
.empty-status {
  text-align: center;
  padding-top: 100rpx;
}

.empty-icon { font-size: 100rpx; margin-bottom: 30rpx; }
.empty-tip { font-size: 28rpx; color: #94a3b8; }
